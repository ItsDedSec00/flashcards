{
  "name": "flashcard-app",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node --watch server/index.js",
    "client": "npm run dev --prefix client",
    "postinstall": "npm install --prefix server && npm install --prefix client",
    "build": "node client/node_modules/vite/bin/vite.js build --config client/vite.config.js",
    "start": "cross-env NODE_ENV=production node server/index.js"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3"
  }
}
